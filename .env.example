# ── Mia configuration ─────────────────────────────────────────────
# Copy to `.env` and fill in. `.env` is git-ignored — never commit real secrets.
# Nothing here is required to pass Gate G0; each secret is enforced only by the
# phase that first needs it.

# Owner lock — your numeric Telegram user id (get it from @userinfobot).
# From Phase 1, messages from any other chat id are silently ignored.
OWNER_TELEGRAM_ID=

# ── Provider secrets ──────────────────────────────────────────────
# Claude (reasoning). https://console.anthropic.com/  — needed from Phase 1
ANTHROPIC_API_KEY=
# OpenAI (Whisper voice transcription). https://platform.openai.com/ — Phase 2
OPENAI_API_KEY=
# Telegram bot token from @BotFather — needed from Phase 1
TELEGRAM_BOT_TOKEN=

# ── Google OAuth (needed from Phase 4) ────────────────────────────
GOOGLE_OAUTH_CLIENT_SECRETS_FILE=./secrets/google_client_secret.json
GOOGLE_TOKEN_FILE=./data/google_token.json

# ── Models (verify current ids against docs at each phase's build) ─
CLAUDE_MODEL_DEFAULT=claude-sonnet-4-6
CLAUDE_MODEL_ROUTER=claude-haiku-4-5-20251001
WHISPER_MODEL=whisper-1

# ── Runtime & guardrails ──────────────────────────────────────────
MIA_ENV=dev
LOG_LEVEL=INFO
DATA_DIR=./data
DEFAULT_TIMEZONE=Europe/Madrid
DAILY_BUDGET_USD=1.0
MAX_TOOL_ITERATIONS=8
